[core]
	excludesfile = /home/hendrik/.gitignore
	autocrlf = input
	safecrlf = warn
[diff]
	tool = vimdiff
[merge]
	tool = vimdiff
[commit]
	gpgSign = true
	template = ~/.gitmessage
[fetch]
	prune = true
[rebase]
	autosquash = true
[alias]
	branches = for-each-ref --sort=-committerdate --format=\"%(color:blue)%(authordate:relative)\t%(color:red)%(authorname)\t%(color:white)%(color:bold)%(refname:short)\" refs/remotes
    undo = reset --soft HEAD~1
