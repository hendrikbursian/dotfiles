{
  "Insert breakpoint mixin": {
    "prefix": "bp",
    "body": ["@include breakpoint($1) {", "\t$2", "}"],
    "description": "Add min-width query with breakpoint."
  },
  "Insert min-width media query": {
    "prefix": "qmin",
    "body": ["@media (min-width: screensize($1)) {", "    $2", "}"],
    "description": "Insert min-width media query."
  },
  "Insert red border": {
    "prefix": "bred",
    "body": ["border: 1px solid #f00;"],
    "description": "Insert red border for debugging."
  },
  "Insert red dotted border": {
    "prefix": "bred",
    "body": ["border: 2px dotted #f007;"],
    "description": "Insert red dotted border to debug selectors"
  }
}
