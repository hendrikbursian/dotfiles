{
    "breadcrumbs.enabled": true,
    "breadcrumbs.filePath": "on",
    "editor.cursorSurroundingLines": 10,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.dragAndDrop": true,
    "editor.fontFamily": "'Droid Sans Mono', 'monospace', monospace, 'Droid Sans Fallback'",
    "editor.fontSize": 16,
    "editor.lineNumbers": "on",
    "editor.minimap.enabled": false,
    "editor.minimap.renderCharacters": true,
    "editor.renderLineHighlight": "line",
    "editor.renderWhitespace": "none",
    "editor.suggestSelection": "first",
    "editor.tabCompletion": "on",
    "editor.trimAutoWhitespace": true,
    "editor.quickSuggestionsDelay": 0,
    "editor.codeActionsOnSave": {
        "source.fixAll.tslint": true
    },
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.enableDragAndDrop": true,
    "search.quickOpen.includeHistory": true,
    "search.smartCase": false,
    "terminal.integrated.rendererType": "dom",
    "window.closeWhenEmpty": false,
    "window.enableMenuBarMnemonics": false,
    "window.menuBarVisibility": "hidden",
    "window.newWindowDimensions": "default",
    "window.openFoldersInNewWindow": "on",
    "window.restoreFullscreen": false,
    "window.restoreWindows": "one",
    "window.title": "${dirty}${activeEditorLong}${separator}${rootName}${separator}${appName}",
    "window.zoomLevel": -1,
    "workbench.colorTheme": "Nord",
    "workbench.editor.showTabs": false,
    "workbench.editor.enablePreview": true,
    "workbench.editor.enablePreviewFromQuickOpen": true,
    "workbench.panel.defaultLocation": "bottom",
    "workbench.settings.editor": "json",
    "workbench.startupEditor": "newUntitledFile",
    "workbench.useExperimentalGridLayout": false,
    "zenMode.centerLayout": false,
    "zenMode.fullScreen": false,
    "zenMode.hideLineNumbers": false,
    "zenMode.restore": true,

    "git.enabled": true,
    "git.autofetch": true,
    "git.enableCommitSigning": true,
    "git.enableSmartCommit": true,
    "git.branchWhitespaceChar": "-",
    "git.showProgress": true,
    "git.decorations.enabled": true,
    "git.showInlineOpenFileAction": true,
    "git.showPushSuccessNotification": true,
    "git.useForcePushWithLease": true,
    "git.autorefresh": true,
    "diffEditor.ignoreTrimWhitespace": false,

    "gitlens.blame.ignoreWhitespace": false,
    "gitlens.views.repositories.autoRefresh": true,
    "gitlens.advanced.telemetry.enabled": false,

    "gitlab.instanceUrl": "https://gitlab.intern.atmina.systems",

    "rest-client.previewOption": "full",
    "rest-client.enableSendRequestCodeLens": true,
    "rest-client.enableTelemetry": false,
    "rest-client.enableCustomVariableReferencesCodeLens": true,
    "rest-client.previewColumn": "beside",
    "rest-client.previewResponsePanelTakeFocus": true,

    "javascript.preferences.quoteStyle": "single",
    "javascript.preferences.importModuleSpecifier": "non-relative",
    "javascript.updateImportsOnFileMove.enabled": "always",

    "typescript.updateImportsOnFileMove.enabled": "always",
    "typescript.suggest.autoImports": true,
    "typescript.implementationsCodeLens.enabled": true,
    "typescript.preferences.quoteStyle": "single",
    "typescript.referencesCodeLens.enabled": false,
    "typescript.suggest.completeFunctionCalls": true,
    "typescript.tsserver.log": "verbose",

    "tslint.jsEnable": true,
    "tslint.packageManager": "yarn",
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    "hadolint.hadolintPath": "hadolint",

    "prettier.printWidth": 140,
    "prettier.singleQuote": true,
    "prettier.tabWidth": 4,
    "prettier.trailingComma": "none",

    "scss.lint.boxModel": "warning",
    "scss.lint.duplicateProperties": "warning",
    "scss.lint.emptyRules": "error",
    "scss.lint.float": "warning",
    "scss.lint.ieHack": "warning",
    "scss.lint.important": "warning",
    "scss.lint.importStatement": "warning",
    "scss.lint.universalSelector": "warning",

    "sqltools.telemetry": false,
    "sqltools.useNodeRuntime": true,

    "emmet.optimizeStylesheetParsing": false,

    "python.pythonPath": "/usr/bin/python3",
    "python.formatting.blackArgs": ["--line-length=120"],
    "python.linting.lintOnSave": true,
    "python.formatting.provider": "black",
    "python.jediEnabled": false,

    "shellcheck.enable": true,
    "shellcheck.run": "onType",
    "shellcheck.executablePath": "/snap/shellcheck/current/usr/bin/shellcheck",

    "vim.easymotion": true,
    "vim.easymotionMarkerYOffset": 2,
    "vim.easymotionMarkerWidthPerChar": 7,
    "vim.easymotionMarkerHeight": 20,
    "vim.easymotionMarkerFontFamily": "'Droid Sans Mono', 'monospace', monospace, 'Droid Sans Fallback'",
    "vim.easymotionMarkerBackgroundColor": "#2e3440",
    "vim.easymotionMarkerForegroundColorOneChar": "#bf616a",
    "vim.easymotionMarkerForegroundColorTwoChar": "#bf616a",
    "vim.sneak": true,
    "vim.camelCaseMotion.enable": true,
    "vim.incsearch": true,
    "vim.overrideCopy": false, 
    "vim.useSystemClipboard": false,
    "vim.useCtrlKeys": false,
    "vim.autoindent": true,
    "vim.hlsearch": false,
    "vim.ignorecase": true,
    "vim.smartcase": true,
    "vim.insertModeKeyBindings": [
        {
            "before": ["j", "j"],
            "after": ["<Esc>"]
        }
    ],
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": ["<leader>", "d"],
            "after": ["d", "d"]
        },
        {
            "before": ["<C-n>"],
            "commands": [":nohl"]
        }
    ],
    "vim.leader": "<space>",
    "vim.handleKeys": {},
    "vim.debug.silent": true,
    "vim.debug.loggingLevelForAlert": "error",
    "vim.debug.loggingLevelForConsole": "error",

    "[html]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    "[markdown]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    "[python]": {
        "editor.defaultFormatter": "ms-python.python"
    },
    "[shellscript]": {
        "editor.defaultFormatter": "foxundermoon.shell-format"
    },

    "[sql]": {
        "editor.defaultFormatter": "mtxr.sqltools"
    },

    "[xml]": {
        "editor.defaultFormatter": "DotJoshJohnson.xml"
    }
}
